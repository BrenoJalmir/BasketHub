<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/spacing_4xl"
        android:paddingStart="@dimen/spacing_l"
        android:paddingEnd="@dimen/spacing_l"
        android:paddingBottom="@dimen/spacing_xxl">

        <TextView
            android:id="@+id/tvAstTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/ast_title"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAstSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_s"
            android:text="@string/ast_formula"
            android:textColor="@color/text_secondary_light"
            android:textSize="14sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvAstTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etAst"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:hint="@string/ast_hint_ast"
            android:inputType="numberDecimal"
            android:textColor="@android:color/white"
            android:textColorHint="@color/hint_medium"
            android:padding="@dimen/spacing_l"
            android:background="@drawable/hub_button_background"
            app:layout_constraintTop_toBottomOf="@id/tvAstSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etFga"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:hint="@string/ast_hint_fga"
            android:inputType="numberDecimal"
            android:textColor="@android:color/white"
            android:textColorHint="@color/hint_medium"
            android:padding="@dimen/spacing_l"
            android:background="@drawable/hub_button_background"
            app:layout_constraintTop_toBottomOf="@id/etAst"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etFta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:hint="@string/ast_hint_fta"
            android:inputType="numberDecimal"
            android:textColor="@android:color/white"
            android:textColorHint="@color/hint_medium"
            android:padding="@dimen/spacing_l"
            android:background="@drawable/hub_button_background"
            app:layout_constraintTop_toBottomOf="@id/etFga"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etTo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:hint="@string/ast_hint_to"
            android:inputType="numberDecimal"
            android:textColor="@android:color/white"
            android:textColorHint="@color/hint_medium"
            android:padding="@dimen/spacing_l"
            android:background="@drawable/hub_button_background"
            app:layout_constraintTop_toBottomOf="@id/etFta"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalcularAst"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/ast_calculate"
            android:textColor="@android:color/white"
            android:background="@drawable/hub_button_background"
            app:backgroundTint="@color/accent_orange"
            app:layout_constraintTop_toBottomOf="@id/etTo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimparAst"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:text="@string/ast_clear"
            android:textColor="@android:color/white"
            android:background="@drawable/hub_button_background"
            app:layout_constraintTop_toBottomOf="@id/btnCalcularAst"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvResultadoAst"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:text="@string/ast_result_default"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/btnLimparAst"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvFormulaAst"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:text="@string/ast_formula_label"
            android:textColor="@color/text_secondary_light"
            android:textSize="14sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvResultadoAst"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>